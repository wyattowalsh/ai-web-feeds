{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aiwebfeeds.com/schemas/view-filters.json",
  "title": "Custom View Filters Schema",
  "description": "Schema for validating custom view filter definitions in AI Web Feeds client-side features",
  "type": "object",
  "properties": {
    "feedIds": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uuid"
      },
      "description": "Filter by specific feed IDs (empty array = all feeds)"
    },
    "topics": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Filter by topic tags"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Filter by article tags"
    },
    "dateRange": {
      "type": "object",
      "properties": {
        "from": {
          "type": "string",
          "format": "date-time",
          "description": "Start date (ISO 8601)"
        },
        "to": {
          "type": "string",
          "format": "date-time",
          "description": "End date (ISO 8601)"
        }
      },
      "description": "Filter by publication date range"
    },
    "readStatus": {
      "type": "string",
      "enum": ["all", "unread", "read"],
      "default": "all",
      "description": "Filter by read status"
    },
    "starred": {
      "type": "boolean",
      "description": "Filter starred articles only (true) or include all (false/undefined)"
    },
    "priority": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["low", "normal", "high"]
      },
      "description": "Filter by feed priority levels"
    },
    "searchQuery": {
      "type": "string",
      "maxLength": 200,
      "description": "Full-text search query to filter articles"
    },
    "folderIds": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uuid"
      },
      "description": "Filter by folder membership (includes nested folders)"
    }
  },
  "additionalProperties": false
}
