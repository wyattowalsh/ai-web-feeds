{
  "name": "web",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "pnpm build:workers && next build",
    "build:workers": "tsx scripts/build-workers.ts",
    "dev": "next dev --turbo",
    "start": "next start",
    "postinstall": "fumadocs-mdx",
    "lint": "eslint",
    "lint:links": "tsx ./scripts/lint-node.mjs",
    "lint:links:bun": "bun ./scripts/lint.ts",
    "generate:docs": "tsx scripts/generate-python-docs.mjs",
    "export-pdf": "tsx scripts/export-pdf.ts",
    "export-pdf:specific": "tsx scripts/export-pdf-specific.ts",
    "export-pdf:build": "NEXT_PUBLIC_PDF_EXPORT=true pnpm build && pnpm start & sleep 5 && pnpm export-pdf && kill $!",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "d3": "^7.9.0",
    "d3-force": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "dexie": "^4.0.11",
    "dexie-react-hooks": "^2.0.1",
    "feed": "^5.1.0",
    "fumadocs-core": "15.8.5",
    "fumadocs-mdx": "12.0.3",
    "fumadocs-python": "^0.0.5",
    "fumadocs-ui": "15.8.5",
    "katex": "^0.16.25",
    "lucide-react": "^0.545.0",
    "mermaid": "^11.12.0",
    "next": "15.5.5",
    "next-themes": "^0.4.6",
    "onnxruntime-web": "^1.21.0",
    "react": "^19.2.0",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^19.2.0",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "shiki": "^1.0.0",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^3.3.1",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.49.1",
    "@tailwindcss/postcss": "^4.1.14",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/bun": "^1.3.0",
    "@types/d3": "^7.4.3",
    "@types/mdx": "^2.0.13",
    "@types/node": "24.7.2",
    "@types/puppeteer": "^7.0.4",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitest/ui": "^3.0.6",
    "eslint": "^9",
    "eslint-config-next": "15.5.5",
    "happy-dom": "^16.3.0",
    "jsdom": "^25.0.1",
    "next-validate-link": "^1.6.3",
    "postcss": "^8.5.6",
    "puppeteer": "^24.24.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^6.0.7",
    "vitest": "^3.0.6"
  }
}