# AIWebFeeds Environment Configuration
# Copy this file to .env and customize for your environment
# All variables are prefixed with AIWF_ (AI Web Feeds)

# ============================================================================
# Logging Configuration
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
AIWF_LOGGING__LEVEL=INFO

# Console logging
AIWF_LOGGING__CONSOLE=true
AIWF_LOGGING__CONSOLE_COLORIZE=true

# File logging
AIWF_LOGGING__FILE=false
AIWF_LOGGING__FILE_PATH=logs/ai_web_feeds.log
AIWF_LOGGING__FILE_SERIALIZE=true
AIWF_LOGGING__FILE_ROTATION="10 MB"
AIWF_LOGGING__FILE_RETENTION="14 days"
AIWF_LOGGING__FILE_COMPRESSION=gz

# Advanced logging options
AIWF_LOGGING__ENQUEUE=true
AIWF_LOGGING__BACKTRACE=true
AIWF_LOGGING__DIAGNOSE=false

# ============================================================================
# Database Configuration
# ============================================================================

# SQLite (development)
AIWF_DATABASE_URL=sqlite:///data/aiwebfeeds.db

# PostgreSQL (production)
# AIWF_DATABASE_URL=postgresql://user:password@localhost:5432/aiwebfeeds

# ============================================================================
# Feed Fetching Configuration
# ============================================================================

# HTTP timeout in seconds
AIWF_FETCH_TIMEOUT=30

# Maximum retry attempts for failed requests
AIWF_MAX_RETRIES=3

# User agent string for HTTP requests
AIWF_USER_AGENT="AIWebFeeds/0.1.0"

# Concurrent feed validations (semaphore limit)
AIWF_VALIDATION_CONCURRENCY=10

# ============================================================================
# Data Paths
# ============================================================================

# Directory for data files (YAML, JSON, OPML)
AIWF_DATA_DIR=data

# Feeds YAML file
AIWF_FEEDS_FILE=data/feeds.yaml

# Topics YAML file
AIWF_TOPICS_FILE=data/topics.yaml

# Enriched feeds YAML file
AIWF_ENRICHED_FILE=data/feeds.enriched.yaml

# ============================================================================
# Validation & Quality Settings
# ============================================================================

# Minimum health score for "verified" status (0.0-1.0)
AIWF_MIN_HEALTH_SCORE=0.75

# Feed update check frequency (hours)
AIWF_UPDATE_CHECK_FREQUENCY=24

# ============================================================================
# API Configuration (Future)
# ============================================================================

# API rate limiting (requests per hour per IP)
# AIWF_API_RATE_LIMIT=1000

# Enable API authentication
# AIWF_API_AUTH_ENABLED=false

# ============================================================================
# Development/Testing Overrides
# ============================================================================

# Set to 'true' to use in-memory SQLite for testing
# AIWF_USE_MEMORY_DB=false

# Enable debug mode (verbose error messages)
# AIWF_DEBUG=false

# ============================================================================
# Phase 3B: Real-Time Monitoring & Alerts
# ============================================================================

# Backend API URL (for Next.js API routes to connect to Python backend)
BACKEND_URL=http://localhost:8001

# WebSocket Server
AIWF_WEBSOCKET_PORT=8000
AIWF_WEBSOCKET_CORS_ORIGINS=http://localhost:3000,https://aiwebfeeds.com

# WebSocket Client (Next.js frontend)
NEXT_PUBLIC_WEBSOCKET_URL=http://localhost:8000

# Feed Polling
AIWF_FEED_POLL_INTERVAL_MIN=15
AIWF_FEED_POLL_TIMEOUT=30
AIWF_FEED_POLL_MAX_CONCURRENT=10

# Notifications
AIWF_NOTIFICATION_RETENTION_DAYS=7
AIWF_NOTIFICATION_BUNDLE_THRESHOLD=3
AIWF_NOTIFICATION_BUNDLE_WINDOW_SECONDS=300

# Trending Detection
AIWF_TRENDING_BASELINE_DAYS=3
AIWF_TRENDING_Z_SCORE_THRESHOLD=2.0
AIWF_TRENDING_MIN_ARTICLES=5
AIWF_TRENDING_UPDATE_INTERVAL_HOURS=1

# Email Digests
AIWF_SMTP_HOST=localhost
AIWF_SMTP_PORT=25
AIWF_SMTP_USER=
AIWF_SMTP_PASSWORD=
AIWF_SMTP_FROM=noreply@aiwebfeeds.com
AIWF_DIGEST_MAX_ARTICLES=20

# ============================================================================
# Phase 5: Advanced AI/NLP Configuration
# ============================================================================

# Batch Processing Sizes
AIWF_PHASE5__QUALITY_BATCH_SIZE=100
AIWF_PHASE5__ENTITY_BATCH_SIZE=50
AIWF_PHASE5__SENTIMENT_BATCH_SIZE=100

# Processing Schedules (cron expressions)
AIWF_PHASE5__QUALITY_CRON="*/30 * * * *"
AIWF_PHASE5__ENTITY_CRON="0 * * * *"
AIWF_PHASE5__SENTIMENT_CRON="0 * * * *"
AIWF_PHASE5__TOPIC_MODELING_CRON="0 3 1 * *"

# NLP Models
AIWF_PHASE5__SPACY_MODEL=en_core_web_sm
AIWF_PHASE5__SENTIMENT_MODEL=distilbert-base-uncased-finetuned-sst-2-english
AIWF_PHASE5__TOPIC_MODEL=lda

# Thresholds
AIWF_PHASE5__QUALITY_MIN_WORDS=100
AIWF_PHASE5__ENTITY_CONFIDENCE_THRESHOLD=0.7
AIWF_PHASE5__SENTIMENT_SHIFT_THRESHOLD=0.3
AIWF_PHASE5__TOPIC_COHERENCE_MIN=0.5

# Resources
AIWF_PHASE5__NLP_WORKERS=4
AIWF_PHASE5__MODEL_CACHE_DIR=~/.cache/ai_web_feeds/models
